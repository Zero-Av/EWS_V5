# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  copy to .env and fill in real values
# NEVER commit the actual .env file (it is in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL credentials
POSTGRES_USER=ews_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ews

# Application secrets
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EWS_SECRET_KEY=CHANGE_ME_run_python_secrets_token_hex_32

# Full database connection URL  (must match POSTGRES_* above)
DATABASE_URL=postgresql://ews_user:CHANGE_ME@db:5432/ews

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Anthropic LLM (optional — needed for AI recommendation narrative)
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# HRIS webhook security key (optional — leave unset to disable the endpoint)
# Generate with: openssl rand -hex 24
HRIS_API_KEY=CHANGE_ME

# MLflow experiment tracking (optional)
# Set to the MLflow server URL to enable run tracking, e.g. http://mlflow:5001
MLFLOW_TRACKING_URI=

# Scheduler — set to "true" to enable nightly automated snapshots
SNAPSHOT_SCHEDULE_ENABLED=false
SNAPSHOT_CRON_HOUR=2
SNAPSHOT_CRON_MINUTE=0
