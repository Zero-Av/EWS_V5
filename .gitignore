# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Environments ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.local.example
venv/
.venv/
env/

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
backend/data/pg/

# ── Logs ──────────────────────────────────────────────────────────────────────
backend/logs/*.log
# Keep the directory itself via .gitkeep
!backend/logs/.gitkeep

# ── ML model artifacts (store in a model registry, not git) ──────────────────
backend/models/*.pkl
backend/models/*.json
backend/models/backups/
backend/vector_store/
backend/data/master_training_dataset.csv

# ── Node / Frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.env.local
frontend/.env.production

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
*.dockerignore
