# ── Security ──
EWS_SECRET_KEY=your-32-byte-hex-secret-key-here

# ── Database Connection ──
DATABASE_URL=postgresql://user:password@localhost:5432/ews

# ── PostgreSQL Container Setup (for Docker Compose) ──
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ews

# ── Third-Party Integrations ──
ANTHROPIC_API_KEY=sk-ant-your-key-here
HRIS_API_KEY=your-hris-api-key-here

# ── MLflow Tracking ──
MLFLOW_TRACKING_URI=http://localhost:5001

# ── CORS Configuration ──
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Scheduler Controls ──
SNAPSHOT_SCHEDULE_ENABLED=false
